# Copy this file to .env.local and fill in your keys.
# Both keys are read server-side in API routes so they are never exposed to the client.

# OpenAI API key — powers every AI feature (location analysis, design, procurement, marketing, menu engineering)
OPENAI_API_KEY=your_openai_api_key_here

# Google Maps Platform key — used for Geocoding, Places Nearby Search, Place Details,
# and (client-side) the address Autocomplete widget on the location wizard.
# Enable: Geocoding API, Places API, and Maps JavaScript API.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
